# ============================================
# Turnkey Agent — Environment Variables
# ============================================

# Google Cloud / Gemini
GCP_EMAIL=
GCP_PROJECT_ID=
GEMINI_API_KEY=                          # From Google AI Studio
GOOGLE_CALENDAR_ID=                      # Pre-created calendar
GOOGLE_SERVICE_ACCOUNT=                  # For Calendar API

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=                            # postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres

# Twilio (sub-account)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=                     # The agent's phone number

# Vercel
VERCEL_URL=                              # Auto-set by Vercel
GATEWAY_API_KEY=                         # Vercel AI Gateway key

# BetterAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Bridge
BRIDGE_PORT=3000                         # Voice bridge server port
NGROK_URL=                               # Public URL for Twilio webhooks
